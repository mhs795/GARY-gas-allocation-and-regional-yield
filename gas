#!/bin/bash
# GAS - Run the Nodal Gas Market Optimization Dashboard
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
cd "$DIR"

URL="http://127.0.0.1:8050"

# Make sure the browser is already running before we ever hand it a URL.
# If Brave is cold-started together with a URL argument, it both restores
# the previous session AND opens the new URL, producing two tabs. Pre-warming
# the browser first means xdg-open always lands on an already-running
# instance, which just adds the one tab.
ensure_browser_running() {
    if pgrep -x brave-browser >/dev/null 2>&1; then
        return
    fi
    if command -v brave-browser >/dev/null 2>&1; then
        nohup brave-browser >/dev/null 2>&1 &
    fi
    for i in $(seq 1 20); do
        pgrep -x brave-browser >/dev/null 2>&1 && break
        sleep 0.25
    done
    sleep 1
}

open_browser() {
    ensure_browser_running
    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$URL"
    elif command -v open >/dev/null 2>&1; then
        open "$URL"
    fi
}

# If a server is already running, stop it so we always relaunch the latest code.
if lsof -ti :8050 >/dev/null 2>&1; then
    echo "Stopping existing GARY server on :8050..."
    lsof -ti :8050 | xargs -r kill 2>/dev/null
    # Wait for the port to free (up to ~5s); force-kill if it won't let go.
    for i in $(seq 1 20); do
        lsof -ti :8050 >/dev/null 2>&1 || break
        sleep 0.25
    done
    if lsof -ti :8050 >/dev/null 2>&1; then
        lsof -ti :8050 | xargs -r kill -9 2>/dev/null
        sleep 1
    fi
fi

# Start the server in the background
source venv/bin/activate
export PYTHONPATH=$PYTHONPATH:$(pwd)/src
python src/dashboard.py &
SERVER_PID=$!

# Wait for it to be ready (up to 15 seconds)
echo "Starting GARY..."
for i in $(seq 1 30); do
    if lsof -ti :8050 >/dev/null 2>&1; then
        break
    fi
    sleep 0.5
done

# Open browser
open_browser

echo "GARY running at $URL  (PID $SERVER_PID)"
echo "Press Ctrl+C to stop."
wait $SERVER_PID
